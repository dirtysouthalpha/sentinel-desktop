{
  "name": "Check for Driver Updates",
  "description": "Opens Device Manager and triggers a scan for hardware changes to detect new or updated drivers.",
  "author": "sentinel-desktop",
  "created": "2026-05-12T00:00:00",
  "version": "3.0",
  "tags": ["driver", "device manager", "hardware", "update"],
  "category": "hardware",
  "icon": "🔌",
  "parameters": [],
  "steps": [
    {
      "action": "start_process",
      "params": { "command": "devmgmt.msc", "args": "" },
      "description": "Open Device Manager",
      "wait_after_ms": 2000
    },
    {
      "action": "click",
      "params": { "target": "menu#Action" },
      "description": "Click the Action menu in menu bar",
      "wait_after_ms": 500
    },
    {
      "action": "click",
      "params": { "target": "menuitem#ScanForHardwareChanges" },
      "description": "Click 'Scan for hardware changes'",
      "wait_after_ms": 3000
    },
    {
      "action": "press_key",
      "params": { "key": "Tab" },
      "description": "Ensure focus is on device list",
      "wait_after_ms": 300
    },
    {
      "action": "press_key",
      "params": { "key": "Home" },
      "description": "Jump to top of device list",
      "wait_after_ms": 300
    },
    {
      "action": "press_key",
      "params": { "key": "Apps" },
      "description": "Open context menu on first device",
      "wait_after_ms": 500
    },
    {
      "action": "click",
      "params": { "target": "menuitem#UpdateDriver" },
      "description": "Click 'Update driver' from context menu",
      "wait_after_ms": 1500
    },
    {
      "action": "click",
      "params": { "target": "button#SearchAutomatically" },
      "description": "Click 'Search automatically for drivers'",
      "wait_after_ms": 5000
    },
    {
      "action": "click",
      "params": { "target": "button#Close" },
      "description": "Close the driver update results dialog",
      "wait_after_ms": 500
    },
    {
      "action": "press_key",
      "params": { "key": "Alt+F4" },
      "description": "Close Device Manager",
      "wait_after_ms": 500
    }
  ]
}
