# Sentinel runtime data (NEVER commit — contains API keys!)
config.json
sentinel_log_*.json
logs/
forensic_*.json
# AuthManager bootstraps an admin user into config/users.json on first
# AgentEngine instantiation; that file is per-deployment and contains
# password hashes + API keys.
/config/users.json
# Scheduler stores runtime task state here
/config/scheduled_tasks.json

# Local screenshots / templates used for click_image
screenshots/
templates/

# Logs
*.log

# Local-only environment overrides
.env
.env.local
